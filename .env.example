# Bu dosyayı ".env" olarak kopyala ve değerleri doldur.

# Anthropic (Claude) API anahtarı — https://console.anthropic.com/ > API Keys
ANTHROPIC_API_KEY=

# Supabase proje bilgileri — Supabase panelinde:
# Project Settings > Data API (URL)  ve  API Keys (Secret key / service_role)
# DİKKAT: bu anahtar gizli tutulmalı, asla tarayıcıya/istemciye koyma.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# İsteğe bağlı: model (varsayılan claude-opus-4-8)
MODEL=claude-sonnet-5

# Voyage AI — konuşmaları "duruma göre" bulmak için embedding (RAG).
# Anahtar: https://dashboard.voyageai.com/ > API Keys
VOYAGE_API_KEY=
# İsteğe bağlı: model ve boyut (varsayılan voyage-3.5 / 1024).
# EMBED_DIM değiştirirsen schema.sql'deki vector(1024) ile eşitle ve yeniden gömle.
EMBED_MODEL=voyage-3.5
EMBED_DIM=1024
